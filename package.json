{
  "name": "nokturne",
  "version": "0.1.0",
  "description": "Framework-agnostic dark mode and light/dark theming with no flash (no-FOUC). ~1 kB vanilla core plus thin React, Vue, Svelte, and Angular adapters.",
  "type": "module",
  "sideEffects": false,
  "license": "MIT",
  "author": "Erwan Heschung",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ErwanHeschung/Nokturne.git"
  },
  "homepage": "https://github.com/ErwanHeschung/Nokturne#readme",
  "bugs": {
    "url": "https://github.com/ErwanHeschung/Nokturne/issues"
  },
  "keywords": [
    "theme",
    "theming",
    "dark-mode",
    "light-mode",
    "dark-theme",
    "theme-switcher",
    "theme-toggle",
    "color-scheme",
    "prefers-color-scheme",
    "system-theme",
    "no-flash",
    "no-fouc",
    "fouc",
    "flicker",
    "react",
    "vue",
    "svelte",
    "angular",
    "vite",
    "tailwind",
    "ssr",
    "framework-agnostic",
    "typescript",
    "css-variables"
  ],
  "main": "./dist/core.cjs",
  "module": "./dist/core.js",
  "types": "./dist/core.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/core.d.ts",
        "default": "./dist/core.js"
      },
      "require": {
        "types": "./dist/core.d.cts",
        "default": "./dist/core.cjs"
      }
    },
    "./script": {
      "import": {
        "types": "./dist/script.d.ts",
        "default": "./dist/script.js"
      },
      "require": {
        "types": "./dist/script.d.cts",
        "default": "./dist/script.cjs"
      }
    },
    "./vite": {
      "import": {
        "types": "./dist/vite.d.ts",
        "default": "./dist/vite.js"
      },
      "require": {
        "types": "./dist/vite.d.cts",
        "default": "./dist/vite.cjs"
      }
    },
    "./react": {
      "import": {
        "types": "./dist/adapters/react.d.ts",
        "default": "./dist/adapters/react.js"
      },
      "require": {
        "types": "./dist/adapters/react.d.cts",
        "default": "./dist/adapters/react.cjs"
      }
    },
    "./vue": {
      "import": {
        "types": "./dist/adapters/vue.d.ts",
        "default": "./dist/adapters/vue.js"
      },
      "require": {
        "types": "./dist/adapters/vue.d.cts",
        "default": "./dist/adapters/vue.cjs"
      }
    },
    "./svelte": {
      "import": {
        "types": "./dist/adapters/svelte.d.ts",
        "default": "./dist/adapters/svelte.js"
      },
      "require": {
        "types": "./dist/adapters/svelte.d.cts",
        "default": "./dist/adapters/svelte.cjs"
      }
    },
    "./angular": {
      "import": {
        "types": "./dist/adapters/angular.d.ts",
        "default": "./dist/adapters/angular.js"
      },
      "require": {
        "types": "./dist/adapters/angular.d.cts",
        "default": "./dist/adapters/angular.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup && tsc -p tsconfig.build.json && node scripts/finalize-types.mjs",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "node --test \"test/**/*.test.ts\"",
    "lint:pkg": "publint",
    "check:types": "attw --pack . --profile node16",
    "size": "size-limit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@angular/core": ">=17",
    "react": ">=18",
    "vite": ">=5",
    "vue": ">=3"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    },
    "@angular/core": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "devDependencies": {
    "@angular/core": "^22.0.8",
    "@arethetypeswrong/cli": "^0.18.5",
    "@size-limit/preset-small-lib": "^12.1.0",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "publint": "^0.3.21",
    "react": "^19.2.8",
    "rxjs": "^7.8.2",
    "size-limit": "^12.1.0",
    "tsup": "^8.5.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vue": "^3.5.40"
  }
}
